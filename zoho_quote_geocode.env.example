# Copy this file to a private file such as:
#   zoho_quote_geocode.env
# Then load it on Linux with:
#   set -a
#   source zoho_quote_geocode.env
#   set +a

# Zoho CRM API domain.
# Examples:
#   US: https://www.zohoapis.com/crm/v7
#   Canada: https://www.zohoapis.ca/crm/v7
#   Europe: https://www.zohoapis.eu/crm/v7
ZOHO_CRM_API_BASE_URL=https://www.zohoapis.com/crm/v7

# Zoho Accounts OAuth domain for your data center.
# Examples:
#   US: https://accounts.zoho.com/oauth/v2/token
#   Canada: https://accounts.zoho.ca/oauth/v2/token
#   Europe: https://accounts.zoho.eu/oauth/v2/token
ZOHO_CRM_ACCOUNTS_URL=https://accounts.zoho.com/oauth/v2/token

# Prefer the refresh-token flow for long-running Linux jobs.
# If ZOHO_CRM_ACCESS_TOKEN is set, the script will use it directly.
ZOHO_CRM_ACCESS_TOKEN=
ZOHO_CRM_REFRESH_TOKEN=
ZOHO_CRM_CLIENT_ID=
ZOHO_CRM_CLIENT_SECRET=

# Standard Zoho CRM record APIs do not require a separate org ID header.
# Your OAuth token already belongs to a specific Zoho organization.
# Keep your org ID in your notes if you need it for admin reference, but
# this script does not send it to the CRM records API.
ZOHO_CRM_ORG_ID=

# Module and field API names.
ZOHO_CRM_MODULE=Quotes
ZOHO_QUOTE_SHIPPING_STREET_FIELD=Shipping_Street
ZOHO_QUOTE_SHIPPING_CITY_FIELD=Shipping_City
ZOHO_QUOTE_SHIPPING_STATE_FIELD=Shipping_State
ZOHO_QUOTE_SHIPPING_POSTAL_CODE_FIELD=Shipping_Code
ZOHO_QUOTE_SHIPPING_COUNTRY_FIELD=Shipping_Country

# Replace these with your real latitude and longitude field API names.
ZOHO_QUOTE_LATITUDE_FIELD=
ZOHO_QUOTE_LONGITUDE_FIELD=

# Google Geocoding API key.
GOOGLE_MAPS_API_KEY=
ZOHO_QUOTE_FAILURE_REPORT_PATH=quote-geolocation-failures.xlsx

# Optional runtime tuning.
ZOHO_CRM_PAGE_SIZE=200
ZOHO_CRM_TIMEOUT_SECONDS=30
GOOGLE_GEOCODE_MAX_RETRIES=3
GOOGLE_GEOCODE_RETRY_DELAY_SECONDS=1
LOG_LEVEL=INFO
